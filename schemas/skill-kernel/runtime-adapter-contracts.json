      "memory",
      "promotion",
      "install_policy",
      "kernel.source_paths"
    ],
    "never_authoritative_in_adapter": [
      "workflow logic",
      "memory writeback policy",
      "validation gate definitions",
      "private paths or credentials"
    ]
