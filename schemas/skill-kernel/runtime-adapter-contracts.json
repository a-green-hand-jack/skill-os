  "field_classes": {
    "runtime_mappable": [
      "kernel.kernel_id -> SKILL.md frontmatter.name",
      "profile.intent -> SKILL.md frontmatter.description",
      "profile.name -> runtime_projection.profile_name",
      "routing.entrypoints -> runtime_projection.routing_hints.entrypoints",
      "skills.required -> runtime_projection.routing_hints.required_skills",
      "adapters.selection_semantics -> runtime_projection.routing_hints.selection_semantics"
